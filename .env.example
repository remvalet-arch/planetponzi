# URL canonique du site (Open Graph, metadata). Sur Vercel : https://votre-projet.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Vercel : définir les mêmes clés dans Project Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Uniquement côté serveur (Route Handler / Server Action) — ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=
